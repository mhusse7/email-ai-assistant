# ===========================================
# EMAIL AI ASSISTANT - ENVIRONMENT CONFIG
# ===========================================

# Email Configuration (iCloud)
IMAP_HOST=imap.mail.me.com
IMAP_PORT=993
IMAP_USER=hussem5@icloud.com
IMAP_PASSWORD=your-app-specific-password

SMTP_HOST=smtp.mail.me.com
SMTP_PORT=587
SMTP_USER=hussem5@icloud.com
SMTP_PASSWORD=your-app-specific-password

# Whitelist (comma-separated)
ALLOWED_SENDERS=hamadax.alaa@gmail.com,mohammed.hussein@td.com

# Gemini API
GEMINI_API_KEY=your-gemini-api-key

# SerpAPI for web search
SERPAPI_KEY=your-serpapi-key

# PostgreSQL (Chat Memory)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=email_assistant
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password

# Qdrant Vector Store
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=email_conversations

# App Settings
POLLING_INTERVAL_SECONDS=30
LOG_LEVEL=INFO
ERROR_NOTIFICATION_EMAIL=hamadax.alaa@gmail.com
